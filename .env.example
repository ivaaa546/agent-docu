# Clave API de Gemini (obtener en Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here

# Puerto del servidor backend Fastify
PORT=3001

# Ruta a la base de datos SQLite
DATABASE_PATH=./local.db

# Secreto para firmar las cookies de sesión (mínimo 32 caracteres)
SESSION_SECRET=supersecret-minimum-32-characters-for-cookie-signature
